<Window x:Class="WpfApp1.SkibiditoiletDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="Editace zákazníka" Height="250" Width="400">
    <Window.Resources>
        <local:UpperConverter x:Key="myConv" />
    </Window.Resources>
    <StackPanel>
        <DockPanel/>
        <!--      Visibility="{Binding FirstName, Converter={StaticResource nullToVisibility}}"   -->
        <Label Content="Jméno" />
        <TextBox Text="{Binding FirstName, Converter={StaticResource myConv}}" />

        <DockPanel>
            <Label Content="Příjmení" />
            <TextBox Text="{Binding LastName}" />
        </DockPanel>
        <local:FormRow Label="Jméno 2" Value="{Binding FirstName}"/>
        <local:FormRow Label="Příjmení 2" Value="{Binding LastName}"/>
    </StackPanel>
</Window>
